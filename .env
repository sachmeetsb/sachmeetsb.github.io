# Vapi voice assistant (the orb). Copy to `.env` and fill in.
# Get these from https://dashboard.vapi.ai
#  - Public key: Vapi dashboard → API Keys → Public Key (safe for the browser)
#  - Assistant ID: create an assistant, then copy its ID
#
# In the assistant's system prompt, reference these template variables so it
# receives the live page context:
#   {{pageContent}}     — a text snapshot of the page when the call starts
#   {{currentSection}}  — what the user is looking at when the call starts
# (Live scroll updates are pushed as system messages during the call.)
VITE_VAPI_PUBLIC_KEY=c8367048-dde9-4895-93c7-5ac3f1d5fb3d
VITE_VAPI_ASSISTANT_ID=0f0a7576-b087-4a6b-80d0-08832003e5cb
